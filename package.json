{
    "name": "@utajum/wsdl-tsclient",
    "version": "2.0.0",
    "description": "Generate typescript soap client with typescript definitons from WSDL file.",
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "default": "./dist/src/index.js"
        }
    },
    "bin": {
        "wsdl-tsclient": "dist/src/cli.js"
    },
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "pretest": "rm -rf ./test/generated",
        "test": "vitest run",
        "preversion": "npm test && npm run build",
        "prepublishOnly": "npm test && npm run dist",
        "dev": "tsx ./dev.ts",
        "dist": "tsc",
        "build": "tsc",
        "lint": "tsc --noEmit",
        "lint:fix": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/utajum/wsdl-tsclient.git"
    },
    "keywords": [
        "soap",
        "soap-client",
        "wsdl",
        "wsdl-client",
        "typescript"
    ],
    "author": "utajum",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/utajum/wsdl-tsclient/issues"
    },
    "homepage": "https://github.com/utajum/wsdl-tsclient#readme",
    "devDependencies": {
        "@tsconfig/node24": "24.0.4",
        "@types/node": "25.5.0",
        "@types/yargs": "17.0.35",
        "prettier": "3.8.1",
        "tsx": "^4.21.0",
        "typescript": "6.0.2",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "camelcase": "9.0.0",
        "sanitize-filename": "1.6.4",
        "soap": "1.8.0",
        "ts-morph": "27.0.2",
        "yargs": "18.0.0"
    }
}
